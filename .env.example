# Recipient wallet that receives charges on Tempo Moderato testnet.
# Create a funded testnet account:  npx mppx account create
# then paste its address here.
RECIPIENT_ADDRESS=

# Server secret used to sign/verify payment challenges.
# Dev fallback (the server auto-generates one if this is blank, but it won't
# survive a restart). Generate a stable one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MPP_SECRET_KEY=

# Port the server listens on.
PORT=3000

# Private key for the agent client (agents/run.ts). Required to run `npm run agent`.
# The value below is the well-known public anvil/hardhat account #0 — fine as a dev
# placeholder, but it holds no real funds. Use your own funded key to settle charges.
AGENT_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
