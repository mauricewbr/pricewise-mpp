# Recipient wallet that receives charges on Tempo Moderato testnet.
# Create a funded testnet account:  npx mppx account create
# then paste its address here.
RECIPIENT_ADDRESS=

# Server secret used to sign/verify payment challenges.
# Dev fallback (the server auto-generates one if this is blank, but it won't
# survive a restart). Generate a stable one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MPP_SECRET_KEY=

# Port the server listens on.
PORT=3000

# Anthropic API key for the live Claude agent (agents/live.ts, `npm run live`).
# Only needed for the live-agent demo; the scripted agent/seed flows don't use it.
ANTHROPIC_API_KEY=

# Agent identities are mppx keychain accounts (see `npx mppx account list`), resolved by
# name via `--account`. No private keys live here — they stay in the OS keychain.
# Create + fund demo accounts, e.g.:
#   npx mppx account create --account regular  && npx mppx account fund --account regular  --network testnet
#   npx mppx account create --account newagent && npx mppx account fund --account newagent --network testnet

# DEV/DEMO ONLY. Enables POST /admin/seed (used by `npm run seed`) to set a wallet's
# starting loyalty count for a live threshold-crossing demo. This mutates pricing
# state — leave unset/0 in any real deployment. Set to 1 only for local demos.
# PRICEWISE_ALLOW_SEED=1

# DEMO. Boot-seed a keychain account with prior settled purchases so it already has a
# loyalty tier on startup. Resolved by name from the keychain. Unset to boot with no seed.
# PRICEWISE_SEED_ACCOUNT=regular
# PRICEWISE_SEED_COUNT=15
