# Recipient wallet that receives charges on Tempo Moderato testnet.
# Create a funded testnet account:  npx mppx account create
# then paste its address here.
RECIPIENT_ADDRESS=

# Server secret used to sign/verify payment challenges.
# Dev fallback (the server auto-generates one if this is blank, but it won't
# survive a restart). Generate a stable one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MPP_SECRET_KEY=

# Port the server listens on.
PORT=3000

# Private keys for the two demo personas (agents/run.ts). Required to run `npm run agent`.
# The values below are well-known public anvil/hardhat accounts #1 and #2 — fine as dev
# placeholders, but they hold no real funds. Their addresses are pinned in src/personas.ts
# (the server seeds the regular one). Use your own funded key to settle charges, and
# update src/personas.ts to match if you change an address.
NEW_AGENT_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
REGULAR_AGENT_PRIVATE_KEY=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a
